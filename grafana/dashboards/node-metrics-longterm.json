          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  t.time,\n  t.metric,\n  CASE WHEN t.den = 0 THEN NULL ELSE t.num::double precision / t.den END AS value\nFROM (\n  SELECT\n    (EXTRACT(EPOCH FROM nm.ts) / 3600)::bigint * 3600 * 1000 AS time,\n    n.name AS metric,\n    GREATEST(MAX(nm.cache_hits) - MIN(nm.cache_hits), 0) AS num,\n    GREATEST((MAX(nm.cache_hits) - MIN(nm.cache_hits)) + (MAX(nm.cache_misses) - MIN(nm.cache_misses)), 0) AS den\n  FROM node_metrics nm\n  JOIN nodes n ON n.id = nm.node_id\n  WHERE nm.ts >= $__timeFrom()::timestamptz AND nm.ts <= $__timeTo()::timestamptz\n    AND ('${node:raw}' = '$__all' OR n.name IN (${node:sqlstring}))\n  GROUP BY 1, 2\n) t\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Rate (delta-based)",
      "type": "timeseries"
