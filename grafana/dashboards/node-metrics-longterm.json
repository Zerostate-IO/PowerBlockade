          },
          "format": "time_series",
          "rawSql": "SELECT\n  (EXTRACT(EPOCH FROM nm.ts) / 3600)::bigint * 3600 * 1000 AS time,\n  n.name AS metric,\n  MAX(nm.questions) - MIN(nm.questions) AS value\nFROM node_metrics nm\nJOIN nodes n ON n.id = nm.node_id\nWHERE nm.ts >= $__timeFrom()::timestamptz AND nm.ts <= $__timeTo()::timestamptz\n  AND ('${node:raw}' = '$__all' OR n.name IN (${node:sqlstring}))\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Queries per Hour (delta)",
      "type": "timeseries"
    },
