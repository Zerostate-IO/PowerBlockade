# =====================
# Core
# =====================
TIMEZONE=America/Los_Angeles

# =====================
# Admin UI
# =====================
ADMIN_PORT=8080
# Secret key for session encryption (generate with: openssl rand -base64 48 | tr -d '\n' | tr '+/' '-_' | tr -d '=')
ADMIN_SECRET_KEY=change-me-32+-chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# =====================
# PostgreSQL
# =====================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=powerblockade
POSTGRES_USER=powerblockade
POSTGRES_PASSWORD=change-me

# SQLAlchemy style DSN used by admin-ui
DATABASE_URL=postgresql+psycopg://powerblockade:change-me@postgres:5432/powerblockade

# =====================
# PowerDNS Recursor API
# =====================
RECURSOR_API_KEY=change-me
RECURSOR_API_URL=http://recursor:8082

# =====================
# Primary Ingest (Multi-Node)
# =====================
# URL of primary admin-ui (used by dnstap-processor and sync-agent)
PRIMARY_URL=http://admin-ui:8080

# API key for node authentication (generate with ./scripts/init-env.sh)
PRIMARY_API_KEY=

# =====================
# dnstap-processor
# =====================
# Node identifier (primary or secondary)
NODE_NAME=primary

# Dnstap Unix socket path
DNSTAP_SOCKET=/var/run/dnstap/dnstap.sock

# Protobuf listener for PowerDNS protobuf
PROTOBUF_LISTEN=0.0.0.0:50001

# =====================
# Observability
# =====================
PROMETHEUS_RETENTION_TIME=30d

# =====================
# Grafana
# =====================
GRAFANA_ADMIN_PASSWORD=change-me

# =====================
# Optional GELF Logging (Graylog)
# =====================
GELF_ENABLED=false
GELF_ENDPOINT=

# =====================
# Docker Network Configuration
# =====================
# Docker subnet for PowerBlockade network (change if conflicts with existing network)
# Use /24 subnet by default (e.g., 172.30.0.0/24)
DOCKER_SUBNET=172.30.0.0/24

# IP address for recursor container (fixed within Docker subnet)
RECURSOR_IP=172.30.0.10

# IP address for dnstap-processor container (fixed within Docker subnet)
DNSTAP_PROCESSOR_IP=172.30.0.20

# =====================
# Optional TLS (Let's Encrypt)
# =====================
# Domain for TLS certificates
DOMAIN=localhost

# Email for Let's Encrypt registration
ACME_EMAIL=

# =====================
# Buffer Configuration (dnstap-processor)
# =====================
# Path to buffer database (for events during primary outages)
BUFFER_PATH=/var/lib/dnstap-processor/buffer.db

# Maximum buffer size (default 100MB)
BUFFER_MAX_BYTES=100MB

# Maximum buffer age in seconds (default 24 hours)
BUFFER_MAX_AGE=86400

# =====================
# sync-agent (Secondary Node Only)
# =====================
# Seconds between heartbeats (default 60)
HEARTBEAT_INTERVAL_SECONDS=60

# Seconds between config syncs (default 300)
CONFIG_SYNC_INTERVAL_SECONDS=300

# URL for local recursor API
RECURSOR_API_URL=http://recursor:8082

# Directory for RPZ zone files
RPZ_DIR=/etc/pdns-recursor/rpz

# Path to forward zones file
FORWARD_ZONES_PATH=/etc/pdns-recursor/forward-zones.conf

# Path to metrics buffer (during primary outages)
METRICS_BUFFER_PATH=/var/lib/powerblockade/metrics.db

# Max age for buffered metrics in seconds (default 7 days)
METRICS_BUFFER_MAX_AGE=604800

# DNS server for cache warming (default: dnsdist)
DNS_SERVER=dnsdist
