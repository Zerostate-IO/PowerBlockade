# Minimal PowerDNS Recursor config for PowerBlockade

# Network
local-address=0.0.0.0
local-port=5300
allow-from=172.30.0.0/16, ::1/128

# Control socket (used for reloads)
socket-dir=/var/run/pdns-recursor
socket-mode=0666

# Performance (tune per host)
# Rollback: restore previous values if cache issues arise:
#   max-cache-entries: 500000, max-packetcache-entries: 100000
#   packetcache-ttl: 3600, packetcache-negative-ttl: 30
# See docs/performance/dns-caching-strategy.md#recursor-tuning-matrix
threads=4
pdns-distributes-queries=yes
reuseport=yes
max-cache-entries=2000000      # Record cache (rollback: 500000)
max-packetcache-entries=1000000 # Packet cache (rollback: 100000)
packetcache-ttl=86400          # 24h max (rollback: 3600)
packetcache-negative-ttl=60    # NXDOMAIN/NODATA (rollback: 30)
packetcache-servfail-ttl=5     # SERVFAIL (unchanged)

# RPZ
lua-config-file=/etc/pdns-recursor/rpz.lua

# Forward zones
forward-zones-file=/etc/pdns-recursor/forward-zones.conf

# API
webserver=yes
webserver-address=0.0.0.0
webserver-port=8082
webserver-allow-from=0.0.0.0/0
api-key=${RECURSOR_API_KEY}

# Metrics
# Recursor exposes Prometheus metrics on the webserver at /metrics.
